[Oo]ut/
[Ll]og/
[Ll]ogs/
image_cache/
[Mm]ods/
[Rr]esources/
[Dd]ecompiler/
[Dd]ecompiled_models/
[Cc]onfigs/
[Cc]ompiler/
.opencode/
.pi/
.kimi/
.claudecode/

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

